        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1
      },
      y: 80,
      ease: 'none'
    });

    // ===== SMOOTH REFRESH ON SCROLL TRIGGER UPDATE =====
    ScrollTrigger.refresh();
  </script>
