---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Option Media — Homepage">
    <section class="hero">
      <video class="hero-video" src="/optionmedia/assets/videos/202508_OPTION_FACILITY_EDIT.mp4" autoplay muted loop playsinline preload="metadata" poster="/optionmedia/assets/images/facility_aerial_still.webp"></video>
      <div class="hero-overlay"></div>
      <div class="container hero-grid">
        <div>
          <h1>Experts in all things <span class="hero-h1-highlight">post</span></h1>
          <p>
            Premium post-production, localization and platform delivery,
            all handled in-house for streaming platforms, distributors
            and production partners.
          </p>

          <div class="hero-actions">
            <a class="cta primary" href="/optionmedia/quote">Request a Quote</a>
            <a class="cta secondary" href="/optionmedia/contact">Contact Us</a>
          </div>
        </div>

        <div class="hero-stats">
          <div class="stat-card">
            <svg class="stat-icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="22" cy="22" r="16"/>
              <polyline points="22,12 22,22 29,27"/>
            </svg>
            <div>
              <strong>30+</strong>
              <span>Years in the business</span>
            </div>
          </div>

          <div class="stat-card">
            <svg class="stat-icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4,38 4,22 13,22 13,38"/>
              <polyline points="13,38 13,7 28,5 28,38"/>
              <polyline points="28,38 28,26 40,26 40,38"/>
              <line x1="2" y1="38" x2="42" y2="38"/>
              <line x1="17" y1="15" x2="25" y2="14.5"/>
              <line x1="17" y1="20" x2="25" y2="19.5"/>
              <line x1="17" y1="25" x2="25" y2="24.5"/>
              <rect x="18.5" y="31" width="5" height="7"/>
            </svg>
            <div>
              <strong>2400 m²</strong>
              <span>Premium facility</span>
            </div>
          </div>

          <div class="stat-card">
            <svg class="stat-icon" viewBox="0 0 44 44" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="12" width="32" height="22" rx="3"/>
              <polyline points="6,12 22,26 38,12"/>
            </svg>
            <div>
              <strong>24/7</strong>
              <span>Project support</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="services">
      <div class="container">
        <div class="section-head">
          <div>
            <div class="label">What we do</div>
            <h2>Services</h2>
          </div>
        </div>

        <div class="services">
          <article class="card">
            <div class="card-icon">
              <!-- Post-Production: circle with play icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)">
                <circle cx="12" cy="12" r="10"/>
                <polygon points="10,7.5 10,16.5 17,12" stroke="currentColor" fill="none"/>
              </svg>
            </div>
            <h3>Post-Production</h3>

            <div class="card-sub-label">Image</div>
            <ul>
              <li>Editing</li>
              <li>Color Grading + VFX</li>
            </ul>

            <div class="card-sub-label">Sound</div>
            <ul>
              <li>Foley</li>
              <li>Sound mixing (stereo, 5.1 &amp; Atmos)</li>
              <li>Mastering</li>
            </ul>

            <div>
              <span class="ai-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                </svg>
                AI Enhanced Workflows
              </span>
            </div>
          </article>

          <article class="card">
            <div class="card-icon">
              <!-- Localization: globe -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)">
                <circle cx="12" cy="12" r="10"/>
                <ellipse cx="12" cy="12" rx="4" ry="10"/>
                <line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M3.5 7h17"/>
                <path d="M3.5 17h17"/>
              </svg>
            </div>
            <h3>Localization</h3>

            <div class="card-sub-label">Image</div>
            <ul>
              <li>Title localization</li>
            </ul>

            <div class="card-sub-label">Sound</div>
            <ul>
              <li>Dubbing</li>
              <li>Audio description</li>
            </ul>

            <div class="card-sub-label">Text</div>
            <ul>
              <li>Subtitling</li>
            </ul>

            <div>
              <span class="ai-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                </svg>
                AI Enhanced Workflows
              </span>
            </div>
          </article>

          <article class="card">
            <div class="card-icon">
              <!-- Media Delivery: download to tray -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="7" x2="12" y2="14"/>
                <polyline points="8.5,11.5 12,15 15.5,11.5"/>
                <line x1="8" y1="17" x2="16" y2="17"/>
              </svg>
            </div>
            <h3>Media Delivery</h3>

            <div class="card-sub-label">TV</div>
            <ul>
              <li>DMAT</li>
            </ul>

            <div class="card-sub-label">Cinema</div>
            <ul>
              <li>DCP</li>
            </ul>

            <div>
              <span class="ai-badge">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 11l3 3L22 4"/>
                  <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                </svg>
                Quality Control
              </span>
            </div>
          </article>
        </div>
      </div>
    </section>

